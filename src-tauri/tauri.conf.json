{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bilirubin Detection",
  "version": "0.1.0",
  "identifier": "com.dwiku.bili-app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sistem Deteksi Bilirubin Neonatal",
        "width": 480,
        "height": 854,
        "minWidth": 240,
        "minHeight": 240,
        "resizable": true,
        "fullscreen": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "resources": [
      "../src-python",
      "../models",
      "../requirements-rpi.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
