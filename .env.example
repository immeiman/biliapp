# Copy this file to .env and edit values for your machine.
# Existing OS environment variables still override values from .env.

# ===== Runtime profile =====
# Desktop/VBox testing: desktop, opencv, keras.
# Raspberry Pi 5: raspi5, libcamera, tflite.
BILIRUBIN_DEVICE=desktop
BILIRUBIN_CAMERA_TYPE=opencv
BILIRUBIN_MODEL_BACKEND=keras
BILIRUBIN_MODEL_MODE=stage2
# Legacy fallback only when BILIRUBIN_MODEL_MODE is unset.
BILIRUBIN_USE_STAGE2=true

# ===== Model type selection =====
# "v19" = single-input CNN (Stage1/Stage2, default, WB + optional palette correction)
# "v21" = multi-input CNN + 24 color features (no CCM, WB-only)
# v21 file: models/best_cnn_bilirubin_v21.h5
BILIRUBIN_MODEL_TYPE=v19

# Used by Tauri/run scripts when you need a specific Python interpreter.
# Windows example: BILIRUBIN_PYTHON=C:\BILIRUBIN\tauri-app\biliapp\.venv\Scripts\python.exe
# Raspberry Pi example: BILIRUBIN_PYTHON=/home/bilirubin/BiliApp/biliapp/.venv-lin/bin/python3
BILIRUBIN_PYTHON=

# ===== OpenCV camera =====
# Recommended on Windows desktop/VBox: dshow. Other options: msmf, any.
BILIRUBIN_OPENCV_BACKEND=dshow
BILIRUBIN_CAMERA_INDEX=0
BILIRUBIN_CAMERA_RESOLUTION=3840x2160
BILIRUBIN_CAMERA_PREVIEW_RESOLUTION=640x480
BILIRUBIN_CAMERA_ROTATION=0
BILIRUBIN_CAMERA_AUTO_EXPOSURE=true
BILIRUBIN_CAMERA_BRIGHTNESS=0.0
BILIRUBIN_CAMERA_TIMEOUT_SECONDS=20

# ===== Raspberry Pi/libcamera capture tuning =====
BILIRUBIN_CAPTURE_TIMEOUT_MS=3000
BILIRUBIN_CAPTURE_SHUTTER_US=8000
BILIRUBIN_CAPTURE_GAIN=8
BILIRUBIN_CAPTURE_AWB_GAINS=
BILIRUBIN_CAPTURE_AF_MODE=auto
BILIRUBIN_CAPTURE_AF_RANGE=normal
BILIRUBIN_CAPTURE_AF_SPEED=normal
BILIRUBIN_CAPTURE_AF_ON_CAPTURE=true
BILIRUBIN_CAPTURE_IMMEDIATE=false
BILIRUBIN_CAPTURE_RETRIES=2
BILIRUBIN_CAPTURE_RETRY_DELAY_MS=250
BILIRUBIN_SAVE_FAILED_CAPTURES=true

# ===== Preview stream =====
BILIRUBIN_PREVIEW_POLL_MS=33
BILIRUBIN_PREVIEW_JPEG_QUALITY=70
BILIRUBIN_PREVIEW_FPS=0
BILIRUBIN_PREVIEW_MIN_FPS=5

# ===== Capture gatecheck =====
BILIRUBIN_REQUIRE_PALETTE=true
BILIRUBIN_MIN_GRAY_PATCHES=2
BILIRUBIN_MIN_COLOR_PATCHES=4
BILIRUBIN_MIN_BLUR_SCORE=60
BILIRUBIN_MAX_RAW_PALETTE_MAE=95
BILIRUBIN_MIN_CHECKERBOARD_SCORE=35

# ===== Optional TFLite conversion debug =====
BILIRUBIN_TFLITE_OPTIMIZE=false
BILIRUBIN_TFLITE_TRACEBACK=false

# ===== Offline-first Supabase sync =====
# Remote schema tetap mengikuti Supabase: babies, measurements, devices.
SUPABASE_URL=
SUPABASE_KEY=
BILIRUBIN_DEVICE_ID=
BILIRUBIN_DEVICE_NAME=
# Not used in current offline-first v1. Keep empty until device pairing is enabled.
BILIRUBIN_HOSPITAL_ID=
BILIRUBIN_SYNC_DEVICE_REGISTRY=false
BILIRUBIN_SUPABASE_BUCKET=measurement-images
# Default mengikuti schema gambar. Ubah ke devices_id hanya jika kolom remote final bernama devices_id.
BILIRUBIN_SUPABASE_DEVICE_ID_COLUMN=device_id
BILIRUBIN_SYNC_INTERVAL_SECONDS=60


#======================================RASPIBERRY PI 5 SPECIFIC SETTINGS======================================
BILIRUBIN_DEVICE=raspi5
BILIRUBIN_CAMERA_TYPE=libcamera
BILIRUBIN_MODEL_BACKEND=tflite
BILIRUBIN_MODEL_MODE=stage2
# Legacy fallback only when BILIRUBIN_MODEL_MODE is unset.
BILIRUBIN_USE_STAGE2=true

# ===== Model type selection =====
# "v19" = single-input CNN (Stage1/Stage2, default, WB + optional palette correction)
# "v21" = multi-input CNN + 24 color features (no CCM, WB-only)
# v21 file: models/best_cnn_bilirubin_v21.h5
BILIRUBIN_MODEL_TYPE=v19

BILIRUBIN_CAMERA_RESOLUTION=1920x1080
BILIRUBIN_CAMERA_PREVIEW_RESOLUTION=1280x720
BILIRUBIN_CAMERA_ROTATION=0

BILIRUBIN_CAPTURE_TIMEOUT_MS=3000
BILIRUBIN_CAPTURE_SHUTTER_US=8000
BILIRUBIN_CAPTURE_GAIN=8
BILIRUBIN_CAPTURE_AF_MODE=auto
BILIRUBIN_CAPTURE_AF_RANGE=normal
BILIRUBIN_CAPTURE_AF_SPEED=normal
BILIRUBIN_CAPTURE_AF_ON_CAPTURE=true
BILIRUBIN_CAPTURE_IMMEDIATE=false
BILIRUBIN_CAPTURE_RETRIES=2
BILIRUBIN_CAPTURE_RETRY_DELAY_MS=250

BILIRUBIN_PREVIEW_POLL_MS=33
BILIRUBIN_PREVIEW_JPEG_QUALITY=65
BILIRUBIN_PREVIEW_FPS=30
BILIRUBIN_PREVIEW_MIN_FPS=30

BILIRUBIN_REQUIRE_PALETTE=true
BILIRUBIN_MIN_GRAY_PATCHES=2
BILIRUBIN_MIN_COLOR_PATCHES=4
BILIRUBIN_MIN_BLUR_SCORE=60
BILIRUBIN_MAX_RAW_PALETTE_MAE=95
BILIRUBIN_MIN_CHECKERBOARD_SCORE=35

BILIRUBIN_SAVE_FAILED_CAPTURES=true

# ===== Offline-first Supabase sync (Raspberry Pi) =====
SUPABASE_URL=
SUPABASE_KEY=
BILIRUBIN_DEVICE_ID=
BILIRUBIN_DEVICE_NAME=
BILIRUBIN_SYNC_DEVICE_REGISTRY=false
BILIRUBIN_SUPABASE_BUCKET=measurement-images
# Default mengikuti schema gambar. Ubah ke devices_id hanya jika kolom remote final bernama devices_id.
BILIRUBIN_SUPABASE_DEVICE_ID_COLUMN=device_id
BILIRUBIN_SYNC_INTERVAL_SECONDS=60

# ===== Network / hotspot (Raspberry Pi) =====
BILIRUBIN_API_BIND_HOST=0.0.0.0
BILIRUBIN_NETWORK_DEFAULT_MODE=hotspot
BILIRUBIN_NETWORK_HOTSPOT_SSID=BiliApp-Local
BILIRUBIN_NETWORK_HOTSPOT_PASSWORD=change-me-before-use
BILIRUBIN_NETWORK_HOTSPOT_INTERFACE=wlan0
BILIRUBIN_NETWORK_WIFI_INTERFACE=wlan0
BILIRUBIN_NETWORK_HOTSPOT_PROFILE=biliapp-hotspot
BILIRUBIN_NETWORK_WIFI_PROFILE_PREFIX=biliapp-wifi
BILIRUBIN_NETWORK_FALLBACK_TIMEOUT_SECONDS=30
BILIRUBIN_NETWORK_RESTORE_ON_STARTUP=true
